{
  "name": "@8bitbish/tooltips",
  "version": "1.3.0",
  "description": "Tooltip component for React, Figma plugins, Framer, and vanilla JS",
  "repository": {
    "type": "git",
    "url": "https://github.com/8bitbish/tooltips"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.mjs",
      "require": "./dist/vanilla.js"
    },
    "./dist/tooltip.css": "./dist/tooltip.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/vanilla.ts --format esm,cjs --dts && copyfiles -f src/tooltip.css dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "copyfiles": "^2.4.1",
    "tsup": "^8",
    "typescript": "^5"
  }
}
